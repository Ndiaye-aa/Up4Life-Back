generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusAgendamento {
  PENDENTE
  REALIZADA
  CANCELADA

  @@map("status_agendamento")
}

model Personal {
  id           Int                    @id @default(autoincrement())
  nome         String                 @db.VarChar(50)
  telefone     String                 @unique @db.VarChar(15)
  senha        String                 @db.VarChar(255)
  alunos            Aluno[]
  agendamentos      AgendamentoAvaliacao[]
  treinos           Treino[]
  avaliacoes        Avaliacao[]
  pushSubscriptions PushSubscription[]
  agendasTreino     AgendaTreino[]

  @@map("personal")
}

model Aluno {
  id             Int       @id @default(autoincrement())
  nome           String    @db.VarChar(50)
  telefone       String    @unique @db.VarChar(15)
  senha          String    @db.VarChar(255)
  personalId     Int?      @map("id_personal")
  sexo           String?   @db.Char(1)
  nascimento     DateTime? @db.Date
  historicoSaude String?   @map("historico_saude") @db.Text
  ativo          Boolean   @default(true)
  criadoEm       DateTime? @default(dbgenerated("CURRENT_DATE")) @map("criado_em") @db.Date

  personal          Personal?              @relation(fields: [personalId], references: [id], onDelete: SetNull)
  avaliacoes        Avaliacao[]
  treinos           Treino[]
  agendamentos      AgendamentoAvaliacao[]
  pushSubscriptions PushSubscription[]
  agendaTreino      AgendaTreino?

  @@map("aluno")
}

model PushSubscription {
  id         Int      @id @default(autoincrement())
  alunoId    Int?     @map("id_aluno")
  personalId Int?     @map("id_personal")
  endpoint   String   @unique @db.Text
  p256dh     String   @db.Text
  auth       String   @db.Text
  criadoEm   DateTime @default(now()) @map("criado_em")

  aluno    Aluno?    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  personal Personal? @relation(fields: [personalId], references: [id], onDelete: Cascade)

  @@map("push_subscription")
}

model AgendaTreino {
  id           Int      @id @default(autoincrement())
  personalId   Int      @map("id_personal")
  alunoId      Int      @unique @map("id_aluno")
  dias         Int[]
  horarios     Json?
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  personal Personal @relation(fields: [personalId], references: [id], onDelete: Cascade)
  aluno    Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@map("agenda_treino")
}

model Avaliacao {
  id                   Int      @id @default(autoincrement())
  alunoId              Int?     @map("id_aluno")
  personalId           Int?     @map("id_personal")
  peso                 Decimal  @db.Decimal(5, 2)
  altura               Decimal  @db.Decimal(3, 2)
  idade                Int
  cintura              Decimal? @db.Decimal(5, 2)
  quadril              Decimal? @db.Decimal(5, 2)
  peitoral             Decimal? @db.Decimal(5, 2)
  axilarMedia          Decimal? @map("axilar_media") @db.Decimal(5, 2)
  triceps              Decimal? @db.Decimal(5, 2)
  subescapular         Decimal? @db.Decimal(5, 2)
  abdominal            Decimal? @db.Decimal(5, 2)
  supraIliaca          Decimal? @map("supra_iliaca") @db.Decimal(5, 2)
  coxa                 Decimal? @db.Decimal(5, 2)
  perimetroTorax       Decimal? @map("perimetro_torax") @db.Decimal(5, 2)
  perimetroAbdomen     Decimal? @map("perimetro_abdomen") @db.Decimal(5, 2)
  perimetroCoxa        Decimal? @map("perimetro_coxa") @db.Decimal(5, 2)
  perimetroPanturrilha Decimal? @map("perimetro_panturrilha") @db.Decimal(5, 2)
  perimetroBraco       Decimal? @map("perimetro_braco") @db.Decimal(5, 2)
  perimetroAntebraco   Decimal? @map("perimetro_antebraco") @db.Decimal(5, 2)
  imc                  Decimal? @db.Decimal(5, 2)
  iac                  Decimal? @db.Decimal(5, 2)
  densidadeCorporal    Decimal? @map("densidade_corporal") @db.Decimal(6, 4)
  percentualGordura    Decimal? @map("percentual_gordura") @db.Decimal(5, 2)
  dataAvaliacao        DateTime @default(now()) @map("data_avaliacao")

  aluno       Aluno?                @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  personal    Personal?             @relation(fields: [personalId], references: [id], onDelete: Cascade)
  agendamento AgendamentoAvaliacao?

  @@map("avaliacao")
}

model AgendamentoAvaliacao {
  id           Int               @id @default(autoincrement())
  alunoId      Int               @map("id_aluno")
  personalId   Int               @map("id_personal")
  dataAgendada DateTime          @map("data_agendada")
  status       StatusAgendamento @default(PENDENTE)
  avaliacaoId  Int?              @unique @map("id_avaliacao")
  criadoEm     DateTime          @default(now()) @map("criado_em")

  lembreteVesperaEm DateTime? @map("lembrete_vespera_em")
  lembreteDiaEm     DateTime? @map("lembrete_dia_em")

  aluno     Aluno      @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  personal  Personal   @relation(fields: [personalId], references: [id], onDelete: Cascade)
  avaliacao Avaliacao? @relation(fields: [avaliacaoId], references: [id], onDelete: SetNull)

  @@map("agendamento_avaliacao")
}

model Treino {
  id           Int       @id @default(autoincrement())
  alunoId      Int?      @map("id_aluno")
  personalId   Int?      @map("id_personal")
  objetivo     String    @db.VarChar(100)
  observacoes  String?   @db.Text
  dataValidade DateTime? @map("data_validade")
  criadoEm     DateTime  @default(now()) @map("criado_em")

  aluno    Aluno?       @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  personal Personal?    @relation(fields: [personalId], references: [id], onDelete: Cascade)
  itens    ItemTreino[]

  @@map("treino")
}

model ItemTreino {
  id         Int     @id @default(autoincrement())
  treinoId   Int     @map("id_treino")
  exercicio  String  @db.VarChar(100)
  series     Int
  repeticoes String  @db.VarChar(20)
  carga      String? @db.VarChar(20)
  ordem      Int
  descanso   Int?
  obs        String? @db.Text

  treino Treino @relation(fields: [treinoId], references: [id], onDelete: Cascade)

  @@map("item_treino")
}

model Exercicio {
  id            Int     @id @default(autoincrement())
  nome          String  @unique @db.VarChar(100)
  grupoMuscular String  @map("grupo_muscular") @db.VarChar(50)
  descricao     String? @db.Text

  @@map("exercicio")
}
