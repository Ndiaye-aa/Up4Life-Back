# Porta em que o servidor HTTP escuta.
PORT=3000

# development | production | test
# Em produção: cookies de sessão saem com Secure + SameSite=None, e a
# proteção CSRF (double-submit cookie) é sempre bloqueante (não depende de
# CSRF_ENFORCE). Em desenvolvimento, os cookies são Lax/sem Secure e o CSRF
# fica em modo observação (loga divergências, mas não bloqueia).
NODE_ENV=development

# String de conexão do PostgreSQL (Supabase ou outro). Para migrations, use
# uma conexão direta/sessão (não a pooler em modo transaction), senão
# `prisma migrate dev` pode travar tentando criar o shadow database — use
# `prisma migrate deploy` em produção/CI, que não precisa de shadow database.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Segredo usado para assinar o JWT do access_token. Gere algo longo e
# aleatório (ex: `openssl rand -base64 48`). Obrigatório — a aplicação falha
# ao subir se estiver ausente.
JWT_SECRET=chave_secreta_longa_e_aleatoria

# Compatibilidade: usado apenas se ACCESS_TOKEN_EXPIRES_IN não estiver
# definido. Prefira configurar ACCESS_TOKEN_EXPIRES_IN diretamente.
JWT_EXPIRES_IN=1d

# Duração do cookie/JWT de acesso. Curto por design — a renovação automática
# acontece via POST /auth/refresh usando o refresh_token.
ACCESS_TOKEN_EXPIRES_IN=15m

# Duração do cookie de refresh (sessão "lembrada").
REFRESH_TOKEN_EXPIRES_IN=30d

# Domínio do cookie. Deixe vazio/ausente para cookie "host-only" (recomendado
# quando front e back estão em domínios diferentes, ex: app.up4life.com e
# api.up4life.com). Só defina (ex: ".up4life.com") se front e back
# compartilharem o mesmo domínio raiz e você quiser o cookie válido em todos
# os subdomínios.
COOKIE_DOMAIN=

# Liga o bloqueio (403) do CsrfGuard fora de produção, para testar o rollout
# manualmente (ex: em staging). Em produção o bloqueio já é sempre ativo,
# independente desta variável.
CSRF_ENFORCE=false

# Origens do front permitidas por CORS e usadas implicitamente como
# referência da política de cookies cross-site. Lista separada por vírgula,
# sem barra final. Em produção, liste os domínios reais do front.
FRONTEND_URL=http://localhost:5173,http://localhost:5174
